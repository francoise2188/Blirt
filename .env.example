# Copy to .env.local (never commit .env.local)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_OR_eyJ_legacy_jwt

# Used for QR codes & share links when not in the browser (optional on localhost).
# Example: http://192.168.1.10:3011  or  https://your-domain.com
NEXT_PUBLIC_APP_URL=

# Spotify (Soundtrack Blirt) â€” server-side only (do not prefix with NEXT_PUBLIC_)
# Get these from your Spotify Developer Dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
